{
  "name": "prl-wallet",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check:packages-clean": "./scripts/check-packages-clean.sh",
    "dev": "turbo run dev",
    "lint": "turbo run lint && bash scripts/lint-analytics-schema.sh",
    "lint:analytics": "bash scripts/lint-analytics-schema.sh",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "postinstall": "node ./scripts/fix-noble-hashes-exports.cjs",
    "prepare": "husky",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "landing": "npm run dev -- --filter=@prl-wallet/landing --filter=@prl-wallet/backend",
    "release:local": "bash scripts/release/local-release.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "latest"
  },
  "lint-staged": {
    "{apps,packages}/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "version": "1.3.24",
  "dependencies": {
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
