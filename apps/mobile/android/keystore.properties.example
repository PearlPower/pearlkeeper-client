# Pseudonymous Android release signing — copy to keystore.properties (gitignored)
# and fill in. When this file is absent, release builds fall back to the shared
# debug key (see app/build.gradle), so dev checkouts need nothing here.
#
# Generate a release keystore whose DN carries ONLY the pseudonym — no real name,
# no personal email. Run from apps/mobile/android/ :
#
# keytool -genkeypair -v \
# -keystore pearlkeeper-release.jks \
# -alias pearlkeeper \
# -keyalg RSA -keysize 4096 -validity 10000 \
# -dname "CN=Pearl Keeper, O=Pearl Keeper, C=US"
#
# Then verify the cert subject leaks no identity:
# keytool -list -v -keystore pearlkeeper-release.jks -alias pearlkeeper
#
# BACK UP the .jks file and its passwords somewhere safe and offline. Losing them
# means you can never publish a signed update for this app on the Play Store.

RELEASE_STORE_FILE=pearlkeeper-release.jks
RELEASE_STORE_PASSWORD=change-me
RELEASE_KEY_ALIAS=pearlkeeper
RELEASE_KEY_PASSWORD=change-me
