# backend base URL for indexer + attestation traffic.
#
# Production default (no override needed):
# EXPO_PUBLIC_BACKEND_BASE_URL=https://www.pearlkeeper.com
#
# Local dev — pick the line for your simulator/emulator (Pitfall C-NEW-05):
# iOS simulator (loopback shared with host):
# EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:8787
# Android emulator (10.0.2.2 = host machine):
# EXPO_PUBLIC_BACKEND_BASE_URL=http://10.0.2.2:8787
# Physical device on same LAN (replace IP):
# EXPO_PUBLIC_BACKEND_BASE_URL=http://192.168.x.x:8787

EXPO_PUBLIC_BACKEND_BASE_URL=https://www.pearlkeeper.com

# Android Play Integrity cloud project number.
# EXPO_PUBLIC_ANDROID_CLOUD_PROJECT_NUMBER=000000000000
