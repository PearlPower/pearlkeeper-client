{
  "name": "@prl-wallet/mobile",
  "version": "1.3.22",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node -e \"const { spawnSync } = require('node:child_process'); const args = process.argv.slice(2).map((arg) => arg.replace(/^apps\\/mobile\\//, '')); const result = spawnSync('jest', ['--config', './jest.config.js', ...args], { stdio: 'inherit' }); process.exit(result.status ?? 1);\" --",
    "lint": "node -e \"const { spawnSync } = require('node:child_process'); const args = process.argv.slice(2).map((arg) => arg.replace(/^apps\\/mobile\\//, '')); const result = spawnSync('eslint', args, { stdio: 'inherit' }); process.exit(result.status ?? 1);\" --",
    "typecheck": "tsc --noEmit",
    "release:bump": "bundle exec fastlane bump",
    "release:ios:build": "bundle exec fastlane ios build",
    "release:android:build": "bundle exec fastlane android build"
  },
