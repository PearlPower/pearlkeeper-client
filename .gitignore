# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
*.tsbuildinfo

# tsc-emitted config artifacts (composite project references run vite.config.ts
# through tsc -b without an outDir, so the .js / .d.ts emit lands next to the
# source). The runtime config is the .ts file; the emitted siblings are stale
# byproducts and must never be committed.
apps/*/vite.config.js
apps/*/vite.config.d.ts

